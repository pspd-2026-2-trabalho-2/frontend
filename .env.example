# Keycloak
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=hu
VITE_KEYCLOAK_CLIENT_ID=hu-frontend

# API Gateway (backend). Ignorado enquanto VITE_USE_MOCKS=true.
VITE_API_URL=http://localhost:3000

# Quando true, todas as chamadas a /api/* são interceptadas pelo MSW
# (src/mocks) em vez de irem para VITE_API_URL. O login continua
# sempre real contra o Keycloak, independente deste valor.
VITE_USE_MOCKS=true
