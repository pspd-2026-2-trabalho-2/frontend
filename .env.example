# Keycloak (cluster kiriland, realm do grupo 3)
# Em dev use /keycloak (proxy do Vite em vite.config.ts) — o Keycloak do
# professor não devolve header CORS na resposta POST do token, então falar
# direto do browser dá "Failed to fetch". Para falar direto use
# https://kiriland.unb.br/keycloak.
VITE_KEYCLOAK_URL=/keycloak
VITE_KEYCLOAK_REALM=grupo03
VITE_KEYCLOAK_CLIENT_ID=pseudopep-frontend

# API Gateway (backend)
VITE_API_URL=http://localhost:8080
